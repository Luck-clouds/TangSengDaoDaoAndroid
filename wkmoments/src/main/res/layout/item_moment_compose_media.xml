<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="96dp">

    <ImageView
        android:id="@+id/mediaIv"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop" />

    <ImageView
        android:id="@+id/addIv"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_moment_add_media"
        android:padding="22dp"
        android:src="@drawable/icon_moment_add"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/playIv"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_gravity="center"
        android:src="@drawable/icon_moment_play"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/deleteIv"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="end|top"
        android:layout_margin="6dp"
        android:src="@drawable/icon_moment_delete" />

    <ImageView
        android:id="@+id/selectedIv"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        android:src="@drawable/icon_moment_selected"
        android:visibility="gone" />
</FrameLayout>
