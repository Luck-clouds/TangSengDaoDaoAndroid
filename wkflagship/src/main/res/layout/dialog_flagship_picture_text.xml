<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/cancelTv"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="@string/cancel"
            android:textColor="#CCCCCC"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/confirmTv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp"
            android:text="@string/flagship_picture_complete"
            android:textColor="#32C85A"
            android:textSize="16sp" />
    </LinearLayout>

    <EditText
        android:id="@+id/editText"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginTop="16dp"
        android:background="@android:color/transparent"
        android:gravity="top|start"
        android:hint="@string/flagship_picture_text_hint"
        android:inputType="textMultiLine"
        android:maxLines="5"
        android:textColor="@android:color/white"
        android:textColorHint="#88FFFFFF"
        android:textSize="22sp" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:id="@+id/colorWhiteView"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="14dp"
                android:background="@drawable/selector_oval_white" />

            <View
                android:id="@+id/colorBlackView"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="14dp"
                android:background="@drawable/selector_oval_black" />

            <View
                android:id="@+id/colorRedView"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="14dp"
                android:background="@drawable/selector_oval_red" />

            <View
                android:id="@+id/colorYellowView"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="14dp"
                android:background="@drawable/selector_oval_yellow" />

            <View
                android:id="@+id/colorGreenView"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="14dp"
                android:background="@drawable/selector_oval_green" />

            <View
                android:id="@+id/colorBlueView"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="14dp"
                android:background="@drawable/selector_oval_blue" />

            <View
                android:id="@+id/colorPurpleView"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/selector_oval_purple" />
        </LinearLayout>
    </HorizontalScrollView>

</LinearLayout>
