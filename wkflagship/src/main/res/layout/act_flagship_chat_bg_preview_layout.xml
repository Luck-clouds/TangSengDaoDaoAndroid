<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0E1117"
    android:orientation="vertical">

    <include layout="@layout/wk_title_bar_layout" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/previewIv"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop" />

        <com.chat.base.views.blurview.ShapeBlurView
            android:id="@+id/blurView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <TextView
            android:id="@+id/defaultTipTv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/flagship_chat_bg_default_preview"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/actionLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="14dp"
            android:baselineAligned="false"
            android:gravity="center_vertical|end"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/refreshBtn"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/selector_flagship_chat_bg_refresh_btn"
                android:elevation="6dp"
                android:padding="3dp"
                android:scaleType="centerInside"
                android:src="@mipmap/bg_rotate_large"
                android:tint="@android:color/white"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/patternBtn"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/selector_flagship_chat_bg_pattern_btn"
                android:elevation="6dp"
                android:gravity="center_vertical"
                android:minWidth="62dp"
                android:orientation="horizontal"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/patternCheckIv"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/shape_flagship_chat_bg_check_circle"
                    android:padding="5dp"
                    android:src="@mipmap/msg_check"
                    android:tint="@android:color/white"
                    android:visibility="visible" />

                <TextView
                    android:id="@+id/patternLabelTv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/flagship_chat_bg_pattern"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/blurBtn"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/selector_flagship_chat_bg_pattern_btn"
                android:elevation="6dp"
                android:gravity="center_vertical"
                android:minWidth="62dp"
                android:orientation="horizontal"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/blurCheckIv"
                    android:layout_width="23dp"
                    android:layout_height="23dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/shape_flagship_chat_bg_check_circle"
                    android:padding="3dp"
                    android:src="@mipmap/msg_check"
                    android:tint="@android:color/white"
                    android:visibility="visible" />

                <TextView
                    android:id="@+id/blurLabelTv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/flagship_chat_bg_blur"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="14dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/shape_flagship_chat_bg_bubble_left"
                    android:elevation="2dp"
                    android:paddingStart="14dp"
                    android:paddingTop="11dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="11dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical|bottom"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/leftPreviewContentTv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:maxWidth="220dp"
                            android:text="@string/flagship_chat_bg_preview_left"
                            android:textColor="#313131"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/leftStatusTv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:textColor="#8D8D93"
                            android:textSize="11sp" />
                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="10dp"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/shape_flagship_chat_bg_bubble_right"
                    android:elevation="2dp"
                    android:paddingStart="14dp"
                    android:paddingTop="11dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="11dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical|bottom"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/rightPreviewContentTv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:maxWidth="202dp"
                            android:text="@string/flagship_chat_bg_preview_right"
                            android:textColor="#313131"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/rightStatusTv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:textColor="#8D8D93"
                            android:textSize="11sp" />

                        <ImageView
                            android:id="@+id/rightStatusIv"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_marginStart="3dp"
                            android:src="@mipmap/msg_seen"
                            android:tint="#8D8D93" />
                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#F7F7F7"
        android:elevation="8dp">

        <TextView
            android:id="@+id/setBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingTop="4dp"
            android:paddingEnd="8dp"
            android:paddingBottom="4dp"
            android:text="@string/flagship_chat_bg_set"
            android:textColor="@color/colorAccent"
            android:textSize="16sp"
            android:textStyle="bold" />
    </FrameLayout>
</LinearLayout>
