<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0E1117"
    android:orientation="vertical">

    <include layout="@layout/wk_title_bar_layout" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/shape_flagship_chat_bg_preview_card"
            android:clipToOutline="true">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/previewIv"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop" />

            <com.chat.base.views.blurview.ShapeBlurView
                android:id="@+id/blurView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

            <TextView
                android:id="@+id/defaultTipTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/flagship_chat_bg_default_preview"
                android:textColor="#667085"
                android:textSize="15sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingBottom="26dp">

                <TextView
                    android:layout_width="180dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/shape_flagship_chat_bg_bubble_left"
                    android:paddingStart="14dp"
                    android:paddingTop="10dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="10dp"
                    android:text="@string/flagship_chat_bg_preview_left"
                    android:textColor="#111827"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="170dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/shape_flagship_chat_bg_bubble_right"
                    android:paddingStart="14dp"
                    android:paddingTop="10dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="10dp"
                    android:text="@string/flagship_chat_bg_preview_right"
                    android:textColor="#111827"
                    android:textSize="14sp" />
            </LinearLayout>
        </FrameLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/blurLayout"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#10141D"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:visibility="gone">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/flagship_chat_bg_blur"
            android:textColor="@android:color/white"
            android:textSize="16sp" />

        <com.chat.base.ui.components.SwitchView
            android:id="@+id/blurSwitch"
            android:layout_width="44dp"
            android:layout_height="24dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/setBtn"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="22dp"
        android:background="@drawable/shape_flagship_chat_bg_set_btn"
        android:gravity="center"
        android:text="@string/flagship_chat_bg_set"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold" />
</LinearLayout>
